# ─────────────────────────────────────────────────────────────
#  Calibr – Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the real .env file to version control!
# ─────────────────────────────────────────────────────────────

# ── Groq API (LLM) ──────────────────────────────────────────
# Groq API - free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── Ollama (Local Embeddings) ──────────────────────────────
# Ollama runs locally for embeddings only
OLLAMA_BASE_URL=http://localhost:11434# --- Scraping ---
SCRAPER_API_KEY=your_scraperapi_key_here
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── MongoDB Atlas ──────────────────────────────────────────
# Free-tier cluster connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true
MONGODB_URL=your_mongodb_atlas_connection_string

# Name of the MongoDB database that Calibr will use
DB_NAME=calibr

# ── ChromaDB (local vector store) ────────────────────────
# Local folder where ChromaDB persists embedding vectors
# No signup needed — runs entirely on your machine
CHROMA_PATH=./chroma_db

# ── Adzuna Job API (optional primary source) ─────────────
# Free tier (250 calls/month): https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── JSearch via RapidAPI (optional secondary source) ──────
# Free tier (100 requests/month): https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_rapidapi_key_for_jsearch
